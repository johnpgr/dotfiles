#!/usr/bin/env fish

set -g program_name kotlin-watch

function usage
    printf 'usage: %s path/to/file.kt [main.class.Name] [-- program args...]\n' $program_name >&2
    exit 2
end

set -l watch_args
set -g kotlin_watch_program_args
set -l after_delimiter false

for arg in $argv
    if test "$after_delimiter" = false; and test "$arg" = "--"
        set after_delimiter true
        continue
    end

    if test "$after_delimiter" = true
        set -a kotlin_watch_program_args "$arg"
    else
        set -a watch_args "$arg"
    end
end

if test (count $watch_args) -gt 0
    switch $watch_args[1]
        case -h --help
            usage
    end
end

if test (count $watch_args) -lt 1; or test (count $watch_args) -gt 2
    usage
end

if not command -q kotlin
    printf '%s: kotlin is required\n' $program_name >&2
    exit 1
end

set -l stdin_file
if not isatty stdin
    set -l resolved_stdin (path resolve /proc/self/fd/0 2>/dev/null)
    if test -n "$resolved_stdin"; and path is -f -- $resolved_stdin
        set stdin_file $resolved_stdin
    else
        set -g kotlin_watch_stdin_temp (mktemp -t kotlin-watch-stdin.XXXXXX)
        cat > $kotlin_watch_stdin_temp
        set stdin_file $kotlin_watch_stdin_temp
    end
end

set -l src $watch_args[1]
if not path is -f -- $src
    printf '%s: file not found: %s\n' $program_name $src >&2
    exit 1
end

if test (path extension -- $src) != ".kt"
    printf '%s: expected a .kt file: %s\n' $program_name $src >&2
    exit 1
end

set -l stem (path basename -E -- $src)
set -l out_dir ".out/$stem"

if test (count $watch_args) -eq 2
    set main_class $watch_args[2]
else
    set -l package
    set -l has_named_main_class false
    while read -l line
        if string match -rq '^[[:space:]]*package[[:space:]]+[A-Za-z_][A-Za-z0-9_.]*' -- $line
            set package (string replace -r '^[[:space:]]*package[[:space:]]+([A-Za-z_][A-Za-z0-9_.]*).*' '$1' -- $line)
        end

        if string match -rq "^[[:space:]]*(object|class)[[:space:]]+$stem([^A-Za-z0-9_].*)?\$" -- $line
            set has_named_main_class true
        end
    end < $src

    set -l class_name
    if test "$has_named_main_class" = true
        set class_name $stem
    else
        set -l first (string upper -- (string sub -l 1 -- $stem))
        set -l rest (string sub -s 2 -- $stem)
        set class_name "$first$rest"Kt
    end

    if test -n "$package"
        set main_class "$package.$class_name"
    else
        set main_class "$class_name"
    end
end

function file_fingerprint --argument-names file
    if command -q stat
        stat -c '%n:%y:%s' -- $file | string replace -a ' ' '_'
    else
        printf '%s:%s\n' $file (path mtime -- $file)
    end
end

function bytecode_fingerprint --argument-names out_dir stdin_file
    set -l files $out_dir/**/*.class
    if test (count $files) -eq 0
        return 1
    end

    for file in (path sort -- $files)
        file_fingerprint $file
    end

    if test -n "$stdin_file"
        file_fingerprint $stdin_file
    end
end

function run_kotlin --argument-names out_dir main_class stdin_file
    if test -n "$stdin_file"
        kotlin -cp $out_dir $main_class $kotlin_watch_program_args < $stdin_file
    else
        kotlin -cp $out_dir $main_class $kotlin_watch_program_args
    end
end

function cleanup_stdin_temp --on-event fish_exit
    if set -q kotlin_watch_stdin_temp
        rm -f -- $kotlin_watch_stdin_temp
    end
end

printf 'watching %s for %s\n' $out_dir $main_class >&2
printf 'compile in Neovim with :compiler kotlin | :make\n' >&2
if test -n "$stdin_file"
    printf 'replaying stdin from %s\n' $stdin_file >&2
end
if test (count $kotlin_watch_program_args) -gt 0
    printf 'program args: %s\n' (string join ' ' -- $kotlin_watch_program_args) >&2
end

set -l last_fingerprint

while true
    set -l fingerprint (bytecode_fingerprint $out_dir $stdin_file)
    if test $status -ne 0
        sleep 0.2
        continue
    end

    if test "$fingerprint" != "$last_fingerprint"
        set last_fingerprint "$fingerprint"
        clear
        run_kotlin $out_dir $main_class $stdin_file
    end

    sleep 0.2
end
